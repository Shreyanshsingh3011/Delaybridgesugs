{
  "framework": null,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "0 6 * * *"
    }
  ]
}